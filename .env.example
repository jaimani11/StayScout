# =====================================================================
# StayScout — environment variables
#
# Every variable in this file is OPTIONAL for local development. The app
# runs fully end-to-end with all of them empty (mock providers, in-memory
# session store, anonymous auth). Add one and the corresponding subsystem
# turns on at runtime.
# =====================================================================

# ----- Models -----
# Anthropic API key. Optional. When set, the IntentAgent + MoodSnapshotAgent
# call the real Claude API instead of mock fixtures.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ----- Database (Slice B1) -----
# Postgres connection string. Optional. When set (and not the placeholder),
# session/turn/trip/click data persists to Postgres via Prisma. Otherwise
# StayScout uses an in-memory store (process-local, lost on restart).
# Local dev: install Postgres + run `pnpm db:migrate`.
# Production: Supabase connection string (pooled or direct).
DATABASE_URL=

# ----- Auth (Slice B1) -----
# Clerk auth. Optional. When BOTH keys are set, sign-in is enabled and
# anonymous sessions migrate to authenticated users on sign-in. Otherwise
# the app stays anonymous (cookie-bound session) — saved trips still work.
# Get keys at https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ----- Orchestrator engine (Slice B2) -----
# Pick between the hand-rolled orchestrator (default) and the LangGraph
# engine. Both produce the same event stream — flag exists so the
# LangGraph engine can roll out behind a switch.
#   - "hand-rolled" (or unset): Slice A's imperative orchestrator
#   - "langgraph": StateGraph + checkpointer (MemorySaver default;
#     PostgresSaver when DATABASE_URL is set)
STAYSCOUT_ORCHESTRATOR=

# ----- Providers (Slice B5 + E1) -----
# Real provider integrations. Each one self-registers when ALL of its
# required keys are set; otherwise it's invisible to the router and the
# mock providers (curated Italy + LLM-synthesized) handle the request.
# Adding keys is purely additive — no other env changes needed.
#
# Setup walkthrough lives in docs/providers.md.

# Booking.com Affiliate Partner Network — deeplink-based affiliate flow,
# no search API for unapproved partners. Apply at https://partner.booking.com/
# When BOTH are set, listings flow through the affiliate redirect.
BOOKING_COM_AFFILIATE_ID=
BOOKING_COM_API_KEY=

# Expedia Group / EPS Rapid — real-time hotel search + availability via
# /v3/properties/availability. Apply at
# https://www.partner-solutions.expediagroup.com/
# Auth uses HMAC-SHA512 over (apiKey + sharedSecret + epochSeconds);
# the shared signing module is src/providers/_shared/rapid-signature.ts.
# When BOTH are set, Expedia self-registers as a live provider.
EXPEDIA_API_KEY=
EXPEDIA_SHARED_SECRET=

# Vrbo — Expedia Group's vacation-rental brand, served via the same
# Rapid surface with a category filter. Two patterns:
#   1. Vrbo-only contract: distinct creds (set both VRBO_* below).
#   2. Combined Expedia Group contract: same creds for both products
#      (set VRBO_* equal to EXPEDIA_*).
# Optional VRBO_AFFILIATE_ID for partners with a separate Vrbo
# Affiliate Program id; falls back to VRBO_API_KEY when unset.
VRBO_API_KEY=
VRBO_SHARED_SECRET=
# VRBO_AFFILIATE_ID=

# ----- Observability (Slice B7) -----
# Langfuse keys for trace export. When BOTH are set, every turn becomes
# a Langfuse trace (one span per agent run, with token + cost metadata).
# Get keys at https://cloud.langfuse.com/ — self-hosted users set
# LANGFUSE_HOST as well.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Set to "1" to make /admin (operator dashboard) accessible without
# sign-in even when Clerk is configured. Useful for staging/preview
# deploys. Without this, /admin requires an authenticated session
# whenever Clerk is wired.
STAYSCOUT_ADMIN_PUBLIC=

# ----- Memory subsystem (Slice C1) -----
# Default: in-memory ring buffer + bag-of-words embeddings (zero-cost,
# deterministic). Both flags below are opt-in; absence keeps the
# keyless demo working unchanged.

# Set to "1" alongside DATABASE_URL to use Postgres+pgvector for
# durable cross-session memory. Requires the `vector` extension on the
# database. Schema field is in place; full implementation lands in C1.x.
STAYSCOUT_PGVECTOR=

# Set to "1" alongside ANTHROPIC_API_KEY to use real Anthropic
# embeddings instead of bag-of-words. Each turn embeds the rawInput
# (small per-call cost). Default off; bag-of-words is good enough for
# the prompt sizes we ship. Implementation lands in C1.x.
STAYSCOUT_USE_ANTHROPIC_EMBEDDINGS=

# ----- Billing (Slice C4) -----
# All three must be set for StripeBillingProvider to activate. With ANY
# missing, the demo falls back to MockBillingProvider (every authenticated
# user is premium, anonymous users free). The lib-tests cover both paths.
#
# Use sk_test_... + whsec_... + price_... (test mode) for development.
# Production: swap sk_test_ for sk_live_ and update the webhook secret in
# Stripe Dashboard. No code change required.
#
# Setup walkthrough lives in docs/billing.md (Stripe CLI recipe + the
# documented end-to-end test flow with card 4242 4242 4242 4242).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Optional: override the URL Stripe redirects to after Checkout.
# Defaults to ${request.origin}/billing/return.
# STRIPE_RETURN_URL=

# ----- Test gates -----
# Optional: override mock provider artificial latency (ms). Default 300.
MOCK_PROVIDER_LATENCY_MS=

# Optional: gate the live API integration tests. Set to 1 to run.
RUN_LIVE_API_TESTS=

# Optional: gate the IntentAgent golden-case eval tests. Set to 1 to run.
RUN_EVAL_TESTS=
