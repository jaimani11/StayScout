# =====================================================================
# StayScout — environment variables
#
# Every variable in this file is OPTIONAL for local development. The app
# runs fully end-to-end with all of them empty (mock providers, in-memory
# session store, anonymous auth). Add one and the corresponding subsystem
# turns on at runtime.
# =====================================================================

# ----- Models -----
# Anthropic API key. Optional. When set, the IntentAgent + MoodSnapshotAgent
# call the real Claude API instead of mock fixtures.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ----- Database (Slice B1) -----
# Postgres connection string. Optional. When set (and not the placeholder),
# session/turn/trip/click data persists to Postgres via Prisma. Otherwise
# StayScout uses an in-memory store (process-local, lost on restart).
# Local dev: install Postgres + run `pnpm db:migrate`.
# Production: Supabase connection string (pooled or direct).
DATABASE_URL=

# ----- Auth (Slice B1) -----
# Clerk auth. Optional. When BOTH keys are set, sign-in is enabled and
# anonymous sessions migrate to authenticated users on sign-in. Otherwise
# the app stays anonymous (cookie-bound session) — saved trips still work.
# Get keys at https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ----- Orchestrator engine (Slice B2) -----
# Pick between the hand-rolled orchestrator (default) and the LangGraph
# engine. Both produce the same event stream — flag exists so the
# LangGraph engine can roll out behind a switch.
#   - "hand-rolled" (or unset): Slice A's imperative orchestrator
#   - "langgraph": StateGraph + checkpointer (MemorySaver default;
#     PostgresSaver when DATABASE_URL is set)
STAYSCOUT_ORCHESTRATOR=

# ----- Observability (Slice B planned) -----
# Langfuse keys for trace export. Optional.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# ----- Test gates -----
# Optional: override mock provider artificial latency (ms). Default 300.
MOCK_PROVIDER_LATENCY_MS=

# Optional: gate the live API integration tests. Set to 1 to run.
RUN_LIVE_API_TESTS=

# Optional: gate the IntentAgent golden-case eval tests. Set to 1 to run.
RUN_EVAL_TESTS=
